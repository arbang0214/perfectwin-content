# =============================================================================
# PerfecTwin 환경변수 예시
# =============================================================================
# 로컬 실행 시: 이 파일을 .env 로 복사해 값을 채운다 (.env 는 커밋 금지).
# GitHub Actions 실행 시: 아래 값들은 .env 가 아니라
#   GitHub 저장소 → Settings → Secrets and variables → Actions 에 등록한다.
#   (자세한 셋업 순서는 ONBOARDING.md 참고)
# =============================================================================

# -----------------------------------------------------------------------------
# [성과 모니터링] — GitHub Actions(일간/주간/월간 리포트)에서 사용. 운영 핵심.
# -----------------------------------------------------------------------------

# Claude API — 리포트 본문 생성 (필수)
ANTHROPIC_API_KEY=

# Google 서비스 계정 — GA4 + Search Console 인증 (필수)
#   로컬: 아래 경로에 키 JSON 파일을 둔다 (config/perfectwin-monitoring-*.json 은 .gitignore 처리됨).
#   Actions: GOOGLE_SERVICE_ACCOUNT_JSON 시크릿에 JSON '내용 전체'를 붙여넣으면
#            워크플로가 실행 시 이 경로로 파일을 생성한다.
GOOGLE_SERVICE_ACCOUNT_KEY=config/perfectwin-monitoring-b8809c36eda2.json

# GA4 (Google Analytics 4) — 속성 ID (필수)
GA4_PROPERTY_ID=494841765

# Google Search Console — 대상 사이트 (쉼표 구분, 끝 슬래시 포함)
GSC_SITE_URL=https://perfectwin.ai/,https://blog.perfectwin.ai/,https://ko.blog.perfectwin.ai/

# Slack — 리포트 발송 (필수)
#   Webhook: 간단 발송용 / Bot Token + Channel: 파일·문서 게시용
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# inblog — 영문 블로그(blog.perfectwin.ai) 통계 (필수)
INBLOG_API_KEY=
INBLOG_BLOG_SUBDOMAIN=
INBLOG_BLOG_URL=https://blog.perfectwin.ai

# inblog — 한글 블로그(ko.blog.perfectwin.ai) 통계 (필수)
INBLOG_KO_API_KEY=
INBLOG_KO_BLOG_SUBDOMAIN=
INBLOG_KO_BLOG_URL=https://ko.blog.perfectwin.ai

# 이메일 발송 — Gmail SMTP (선택)
#   GMAIL_APP_PASSWORD 는 일반 비밀번호가 아니라 Google '앱 비밀번호'.
GMAIL_USER=
GMAIL_APP_PASSWORD=
REPORT_EMAIL_TO=

# -----------------------------------------------------------------------------
# [콘텐츠 자동화 파이프라인] — 로컬 콘텐츠 생성 시 사용 (Actions 미사용)
# -----------------------------------------------------------------------------

# Buffer API — LinkedIn/X 소셜 포스트 스케줄링
BUFFER_ACCESS_TOKEN=

# Framer CMS API — 블로그 발행
FRAMER_CMS_API_TOKEN=
FRAMER_COLLECTION_ID=

# Ideogram API — 블로그/소셜 이미지 생성
IDEOGRAM_API_KEY=
